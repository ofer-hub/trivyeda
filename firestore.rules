rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isHostOf(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data.hostUserId
        == request.auth.uid;
    }

    // Used during batch creation: game doc and subcollections written together.
    // getAfter() reads the document state AFTER the batch commits.
    function willBeHostOf(gameId) {
      return getAfter(/databases/$(database)/documents/games/$(gameId)).data.hostUserId
        == request.auth.uid;
    }

    function gameStatusIs(gameId, statuses) {
      return get(/databases/$(database)/documents/games/$(gameId)).data.status
        in statuses;
    }

    // ── gameCodes ─────────────────────────────────────────────────────────────
    match /gameCodes/{code} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && isHostOf(resource.data.gameId);
    }

    // ── games ─────────────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.hostUserId == request.auth.uid;
      allow update: if isSignedIn() && isHostOf(gameId);
      allow delete: if isSignedIn() && isHostOf(gameId);

      // ── participants ────────────────────────────────────────────────────────
      match /participants/{uid} {
        allow read: if isSignedIn();

        allow create: if isSignedIn() && (
          // Real participant creates own doc (non-host)
          (request.auth.uid == uid
            && request.resource.data.isHost == false
            && request.resource.data.nickname.size() <= 30)
          // Host creates bot docs (game already exists)
          || isHostOf(gameId)
          // Host creates their own participant doc in the same batch as the game
          || willBeHostOf(gameId)
        );

        allow update: if isSignedIn() && (
          // Participant may only change their own lastAnswer
          (request.auth.uid == uid
            && resource.data.isHost == false
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['lastAnswer']))
          // Host may update any field (scoring, bots)
          || isHostOf(gameId)
        );

        allow delete: if isSignedIn() && isHostOf(gameId);
      }

      // ── questionsPublic ─────────────────────────────────────────────────────
      match /questionsPublic/{index} {
        allow read:  if isSignedIn();
        allow create: if isSignedIn() && (isHostOf(gameId) || willBeHostOf(gameId));
        allow update, delete: if isSignedIn() && isHostOf(gameId);
      }

      // ── answersPrivate ──────────────────────────────────────────────────────
      // Host reads always. Participants only after reveal.
      match /answersPrivate/{index} {
        allow read: if isSignedIn() && (
          isHostOf(gameId)
          || gameStatusIs(gameId, ['reveal', 'leaderboard', 'finished'])
        );
        allow create: if isSignedIn() && (isHostOf(gameId) || willBeHostOf(gameId));
        allow update, delete: if isSignedIn() && isHostOf(gameId);
      }
    }

    // ── gameStats ─────────────────────────────────────────────────────────────
    match /gameStats/{gameId} {
      allow read:  if true;
      allow write: if isSignedIn();
    }

    // ── topicStats ────────────────────────────────────────────────────────────
    match /topicStats/{key} {
      allow read:  if true;
      allow write: if isSignedIn();
    }
  }
}
