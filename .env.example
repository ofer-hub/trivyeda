# טריווידע — משתני סביבה
# העתק קובץ זה ל-.env.local ומלא את הערכים

# Firebase (לשימוש עתידי — אין להפעיל עד להחלטה מפורשת)
# חשוב: אין להשתמש ב-Firebase Blaze, אין Cloud Functions, אין חיוב
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Gemini AI (לשימוש עתידי — Free Tier בלבד, ללא חיוב)
# חשוב: לא לחבר עד שיש מכסת חינם מוכחת ומאושרת
# VITE_GEMINI_API_KEY=
