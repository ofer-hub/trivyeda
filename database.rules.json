{
  "rules": {
    "games": {
      "$gameId": {
        // כל משתמש מזוהה (אנונימי) יכול לקרוא את נתוני המשחק
        ".read": "auth != null",

        // רק מנהל המשחק יכול לשנות מטה-דאטה של המשחק (סטטוס, אינדקס שאלה וכו׳)
        ".write": "auth != null && (data.child('hostUserId').val() === auth.uid || !data.exists())",

        "participants": {
          "$participantId": {
            // כל משתתף מזוהה יכול לקרוא
            ".read": "auth != null",
            // כל משתתף יכול לכתוב רק את הרשומה שלו; מנהל המשחק יכול לכתוב לכולם
            ".write": "auth != null && ($participantId === auth.uid || root.child('games/' + $gameId + '/hostUserId').val() === auth.uid)"
          }
        },

        "questionsPublic": {
          // שאלות ציבוריות — כל המשתתפים יכולים לקרוא
          ".read": "auth != null",
          // רק מנהל המשחק יכול לכתוב
          ".write": "auth != null && (data.parent().child('hostUserId').val() === auth.uid || !data.parent().exists())"
        },

        "answersPrivate": {
          // TODO: בייצור — להגביל לקריאה רק כשסטטוס המשחק הוא 'reveal' או למנהל בלבד
          // כרגע: כל משתמש מזוהה יכול לקרוא (MVP בלבד)
          ".read": "auth != null",
          // רק מנהל המשחק יכול לכתוב
          ".write": "auth != null && (data.parent().child('hostUserId').val() === auth.uid || !data.parent().exists())"
        }
      }
    },

    "gameCodes": {
      // כולם יכולים לקרוא קודי משחק (כדי למצוא gameId לפי קוד)
      ".read": "auth != null",
      // רק משתמשים מזוהים יכולים ליצור קודים (בעת יצירת משחק)
      ".write": "auth != null"
    }
  }
}
