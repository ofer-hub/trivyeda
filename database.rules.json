{
  "rules": {
    ".read": false,
    ".write": false,

    "games": {
      "$gameId": {
        ".read": "auth != null",

        // כתיבה ברמת המשחק כולו:
        // יצירה — כל משתמש מזוהה יכול ליצור, אך hostUserId חייב להיות הUID שלו.
        // עדכון — רק מנהל המשחק יכול להחליף את כל האובייקט.
        ".write": "auth != null && (!data.exists() ? newData.child('hostUserId').val() === auth.uid : data.child('hostUserId').val() === auth.uid)",

        "participants": {
          ".read": "auth != null",
          "$participantId": {
            // משתתף יכול לכתוב רק לעצמו (ורק עם isHost=false).
            // מנהל המשחק יכול לכתוב לכל משתתף (לצורך demo ועדכון ניקוד).
            ".write": "auth != null && (($participantId === auth.uid && newData.child('isHost').val() != true) || root.child('games/' + $gameId + '/hostUserId').val() === auth.uid)"
          }
        },

        "questionsPublic": {
          ".read": "auth != null",
          // TODO [Security — before Production]:
          // כרגע questionsPublic נגיש לכל משתמש מזוהה.
          // אין צורך להגביל כי answersPublic לא מכיל correctIndex.
          // רק מנהל המשחק יכול לכתוב.
          ".write": "auth != null && root.child('games/' + $gameId + '/hostUserId').val() === auth.uid"
        },

        "answersPrivate": {
          // TODO [Security — before Production]:
          // answersPrivate מכיל correctIndex וחשוף לכל לקוח בשלב ה-MVP.
          // בייצור: להגביל קריאה לסטטוס 'reveal' בלבד, או לשלוח רק שאלה אחת בכל פעם.
          // זה דורש Cloud Functions או ארכיטקטורת fetch דו-שלבית.
          ".read": "auth != null",
          ".write": "auth != null && root.child('games/' + $gameId + '/hostUserId').val() === auth.uid"
        },

        "analyticsPerQuestion": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('games/' + $gameId + '/hostUserId').val() === auth.uid"
        }
      }
    },

    "gameCodes": {
      // קודי משחק: כל משתמש מזוהה יכול לקרוא (לחיפוש gameId לפי קוד).
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "gameStats": {
      ".read": true,
      ".write": "auth != null"
    },

    "topicStats": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}
